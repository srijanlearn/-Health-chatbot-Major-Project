# HealthyPartner v2 — Environment Configuration
# No cloud API keys required! All inference runs locally.

# ── Model Configuration (optional — auto-detected from hardware) ───────────────
# HP_MODEL_TIER=balanced          # ultra_light | balanced | quality
# HP_MAIN_MODEL=qwen3:4b          # Override main generation model
# HP_FAST_MODEL=qwen2.5:0.5b      # Override fast classification model

# ── Ollama Configuration ───────────────────────────────────────────────────────
# OLLAMA_HOST=http://localhost:11434

# ── Server Configuration ───────────────────────────────────────────────────────
# PORT=5000

# ── Twilio (optional — only for WhatsApp/SMS integration) ──────────────────────
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_PHONE_NUMBER=+1234567890
