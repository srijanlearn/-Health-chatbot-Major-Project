# .env.example
# Copy this file to .env and fill in your actual credentials

# Google API Key for Gemini LLM (REQUIRED)
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_api_key_here

# Twilio Credentials (REQUIRED for SMS/WhatsApp functionality)
# Get these from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Twilio Phone Number (the number you'll be using to send/receive messages)
TWILIO_PHONE_NUMBER=+1234567890

# Optional: OpenAI API Key (if you want to use OpenAI models as fallback)
OPENAI_API_KEY=your_openai_api_key_here
